{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TouchAI",
  "version": "0.1.0",
  "identifier": "com.qiancheng.touchai",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TouchAI",
        "width": 750,
        "height": 60,
        "minWidth": 750,
        "minHeight": 60,
        "maxHeight": 700,
        "decorations": false,
        "shadow": false,
        "transparent": true,
        "center": true,
        "resizable": false,
        "focus": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "sql": {
      "scope": {
        "allowed": [
          {
            "path": "data/touchai.db"
          }
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
