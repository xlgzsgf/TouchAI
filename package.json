{
  "name": "touchai",
  "private": true,
  "version": "0.1.0",
  "description": "TouchAI - 一款桌面 AI 工具，愿景是 AI 一触即达",
  "author": "TouchAI Team",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "type:check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "format:check": "prettier --check . --ignore-path .prettierignore",
    "format:fix": "prettier --write . --ignore-path .prettierignore",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-global-shortcut": "^2.3.0",
    "@tauri-apps/plugin-sql": "^2.3.1",
    "kysely": "^0.28.10",
    "marked": "^17.0.1",
    "openai": "^6.16.0",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.13",
    "vue-router": "4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.0.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/ui": "^4.0.15",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.49.0",
    "vite": "^6.0.3",
    "vitest": "^4.0.15",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^2.1.10"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "ai",
    "desktop",
    "tauri",
    "vue",
    "productivity"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/touchai.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/touchai/issues"
  },
  "homepage": "https://github.com/your-username/touchai#readme"
}