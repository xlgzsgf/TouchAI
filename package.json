{
    "name": "touchai",
    "private": true,
    "version": "0.1.0",
    "description": "TouchAI - 一款桌面 AI 工具，愿景是 AI 一触即达",
    "author": "TouchAI Team",
    "license": "GPL-3.0-or-later",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc --noEmit && vite build",
        "preview": "vite preview",
        "tauri": "tauri",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:run": "vitest run",
        "type:check": "vue-tsc --noEmit",
        "lint": "eslint . --fix",
        "format:fix": "prettier --write . --ignore-path .prettierignore && pnpm run format:rust:fix",
        "format:rust:fix": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
        "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml --all-targets",
        "prepare": "husky",
        "db:generate": "drizzle-kit generate",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.71.2",
        "@tailwindcss/vite": "^4.1.18",
        "@tauri-apps/api": "^2.8.0",
        "@tauri-apps/plugin-global-shortcut": "^2.3.0",
        "@tauri-apps/plugin-http": "^2.5.7",
        "@tauri-apps/plugin-log": "^2.8.0",
        "@tauri-apps/plugin-notification": "^2.3.3",
        "@tauri-apps/plugin-opener": "^2.5.3",
        "@tauri-apps/plugin-process": "^2.2.0",
        "@tauri-apps/plugin-sql": "^2.3.1",
        "@vscode/markdown-it-katex": "^1.1.2",
        "drizzle-orm": "^0.45.1",
        "highlight.js": "^11.11.1",
        "katex": "^0.16.28",
        "markdown-it": "^14.1.0",
        "markdown-it-abbr": "^2.0.0",
        "markdown-it-deflist": "^3.0.0",
        "markdown-it-footnote": "^4.0.0",
        "markdown-it-ins": "^4.0.0",
        "markdown-it-mark": "^4.0.0",
        "markdown-it-sup": "^2.0.0",
        "markdown-it-task-lists": "^2.1.1",
        "openai": "^6.16.0",
        "tailwindcss": "^4.1.18",
        "tauri-plugin-clipboard-x-api": "^2.0.1",
        "tauri-plugin-fs-pro-api": "^2.4.0",
        "vue": "^3.5.13",
        "vue-router": "4"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.2.0",
        "@commitlint/config-conventional": "^20.2.0",
        "@eslint/js": "^9.39.1",
        "@tauri-apps/cli": "^2",
        "@types/markdown-it": "^14.1.2",
        "@types/markdown-it-footnote": "^3.0.4",
        "@types/node": "^25.0.1",
        "@vitejs/plugin-vue": "^5.2.1",
        "@vitest/ui": "^4.0.15",
        "@vue/test-utils": "^2.4.6",
        "drizzle-kit": "^0.31.8",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-vue": "^10.6.2",
        "globals": "^16.5.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "markdown-it-sub": "^2.0.0",
        "prettier": "3.7.4",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "typescript": "~5.6.2",
        "typescript-eslint": "^8.49.0",
        "vite": "^6.0.3",
        "vitest": "^4.0.15",
        "vue-eslint-parser": "^10.2.0",
        "vue-tsc": "^2.1.10"
    },
    "lint-staged": {
        "*.{js,ts,vue}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,html,css}": [
            "prettier --write"
        ],
        "src-tauri/**/*.rs": [
            "cargo fmt --manifest-path src-tauri/Cargo.toml --"
        ]
    },
    "keywords": [
        "ai",
        "desktop",
        "tauri",
        "vue",
        "productivity"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/xlgszgf/touchai.git"
    },
    "bugs": {
        "url": "https://github.com/xlgszgf/touchai/issues"
    },
    "homepage": "https://github.com/xlgszgf/touchai#readme"
}
