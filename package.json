{
    "name": "touchai",
    "private": true,
    "version": "0.1.0",
    "description": "TouchAI - 一款桌面 AI 工具，愿景是 AI 一触即达",
    "author": "TouchAI Team",
    "license": "GPL-3.0-or-later",
    "type": "module",
    "packageManager": "pnpm@10.32.1",
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc --noEmit && vite build",
        "preview": "vite preview",
        "tauri": "tauri",
        "tauri:dev:mcp": "tauri dev --features mcp-bridge",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:run": "vitest run --passWithNoTests",
        "type:check": "vue-tsc --noEmit",
        "lint": "eslint . --fix",
        "lint:check": "eslint .",
        "format:check": "prettier --check . --ignore-path .prettierignore",
        "format:fix": "prettier --write . --ignore-path .prettierignore && pnpm run format:rust:fix",
        "format:rust:fix": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
        "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml --all-targets",
        "prepare": "husky",
        "db:generate": "drizzle-kit generate",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@ai-sdk/alibaba": "^1.0.13",
        "@ai-sdk/anthropic": "^3.0.63",
        "@ai-sdk/deepseek": "^2.0.26",
        "@ai-sdk/google": "^3.0.53",
        "@ai-sdk/moonshotai": "^2.0.12",
        "@ai-sdk/openai": "^3.0.48",
        "@ai-sdk/xai": "^3.0.74",
        "@mozilla/readability": "^0.6.0",
        "@tailwindcss/vite": "^4.2.2",
        "@tauri-apps/api": "^2.8.0",
        "@tauri-apps/plugin-dialog": "^2.5.3",
        "@tauri-apps/plugin-fs": "^2.4.5",
        "@tauri-apps/plugin-http": "^2.5.7",
        "@tauri-apps/plugin-notification": "^2.3.3",
        "@tauri-apps/plugin-opener": "^2.5.3",
        "@tauri-apps/plugin-process": "^2.2.0",
        "@tauri-apps/plugin-sql": "^2.3.1",
        "@tiptap/core": "^3.20.1",
        "@tiptap/extension-placeholder": "^3.20.1",
        "@tiptap/pm": "^3.20.1",
        "@tiptap/starter-kit": "^3.20.1",
        "@tiptap/vue-3": "^3.20.1",
        "ai": "^6.0.136",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "drizzle-orm": "^0.45.1",
        "katex": "^0.16.28",
        "markdown-it-emoji": "^3.0.0",
        "markstream-vue": "0.0.7-beta.9",
        "mermaid": "^11.12.3",
        "monaco-editor": "0.52.2",
        "morphdom": "^2.7.8",
        "pinia": "^3.0.4",
        "reka-ui": "^2.8.2",
        "stream-monaco": "^0.0.18",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.2",
        "tauri-plugin-clipboard-x-api": "^2.0.1",
        "tauri-plugin-fs-pro-api": "^2.4.0",
        "turndown": "^7.2.2",
        "vercel-minimax-ai-provider": "^0.0.2",
        "vue": "^3.5.13",
        "vue-draggable-plus": "^0.6.1",
        "vue-router": "4",
        "vue-sonner": "^2.0.9",
        "zhipu-ai-provider": "^0.2.2",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.2.0",
        "@commitlint/config-conventional": "^20.2.0",
        "@eslint/js": "^9.39.1",
        "@iconify-json/bx": "^1.2.3",
        "@tauri-apps/cli": "^2",
        "@types/markdown-it-emoji": "^3.0.1",
        "@types/node": "^25.0.1",
        "@types/turndown": "^5.0.6",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vitest/ui": "^4.1.2",
        "@vue/test-utils": "^2.4.6",
        "drizzle-kit": "^0.31.8",
        "esbuild": "^0.27.4",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-vue": "^10.6.2",
        "globals": "^16.5.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "3.7.4",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "terser": "^5.46.0",
        "typescript": "~5.6.2",
        "typescript-eslint": "^8.49.0",
        "unplugin-icons": "^23.0.1",
        "vite": "^8.0.3",
        "vite-plugin-monaco-editor-esm": "^2.0.2",
        "vitest": "^4.1.2",
        "vue-eslint-parser": "^10.2.0",
        "vue-tsc": "^2.1.10"
    },
    "lint-staged": {
        "*.{js,ts,vue}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,html,css}": [
            "prettier --write"
        ],
        "src-tauri/**/*.rs": [
            "cargo fmt --manifest-path src-tauri/Cargo.toml --"
        ]
    },
    "keywords": [
        "ai",
        "desktop",
        "tauri",
        "vue",
        "productivity"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/xlgszgf/touchai.git"
    },
    "bugs": {
        "url": "https://github.com/xlgszgf/touchai/issues"
    },
    "homepage": "https://github.com/xlgszgf/touchai#readme"
}
